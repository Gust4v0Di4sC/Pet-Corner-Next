{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "petcorner-cosmos-sync",
  "main": "src/index.js",
  "compatibility_date": "2026-04-18",
  "workers_dev": true,
  "r2_buckets": [
    {
      "binding": "PRODUCT_IMAGES_BUCKET",
      "bucket_name": "petcornerimages",
      "preview_bucket_name": "petcornerimages"
    }
  ],
  "vars": {
    "FIREBASE_PROJECT_ID": "petcorner-219fc",
    "ALLOWED_ORIGINS": "http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173,https://pet-corner.vercel.app,https://www.pet-corner.vercel.app",
    "PRODUCT_IMAGE_MAX_BYTES": "5242880"
  }
}
