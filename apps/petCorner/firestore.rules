rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isOwner(customerId) {
      return isAuthenticated() && request.auth.uid == customerId;
    }

    function isValidCustomerToAdminNotificationCreate() {
      return isAuthenticated()
        && request.resource.data.source == "petpage"
        && request.resource.data.actorCustomerId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.category is string
        && request.resource.data.createdAtIso is string
        && request.resource.data.isRead == false;
    }

    function isValidTopLevelOrderCreate() {
      return isAuthenticated()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.orderCode is string
        && request.resource.data.status is string
        && request.resource.data.createdAtIso is string;
    }

    function isValidCustomerOrderMirrorCreate(customerId) {
      return isOwner(customerId)
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.orderCode is string
        && request.resource.data.status is string
        && request.resource.data.createdAtIso is string;
    }

    function isValidDeliveryIssueCreate() {
      return isAuthenticated()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.status is string
        && request.resource.data.createdAtIso is string
        && request.resource.data.updatedAtIso is string;
    }

    function isAppointmentOwner() {
      return isAuthenticated() && resource.data.customerId == request.auth.uid;
    }

    match /clientes/{clientId} {
      allow read, create, update, delete: if isAdmin() || isOwner(clientId);
    }

    match /dogs/{dogId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.ownerCustomerId == request.auth.uid);
      allow create: if isAdmin() || (request.auth != null && request.resource.data.ownerCustomerId == request.auth.uid);
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.ownerCustomerId == request.auth.uid);
    }

    match /prods/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /productCatalog/{document=**} {
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow create: if isAdmin() || isValidTopLevelOrderCreate();
      allow update, delete: if isAdmin();
    }

    match /deliveryIssues/{issueId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow create: if isAdmin() || isValidDeliveryIssueCreate();
      allow update, delete: if isAdmin();
    }

    match /appointmentSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin() || isAppointmentOwner();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /appointmentLocks/{lockId} {
      allow read, write: if isAdmin();
    }

    match /customers/{customerId} {
      allow read, write: if isAdmin() || isOwner(customerId);
    }

    match /customers/{customerId}/orders/{orderId} {
      allow read: if isAdmin() || isOwner(customerId);
      allow create: if isAdmin() || isValidCustomerOrderMirrorCreate(customerId);
      allow update, delete: if isAdmin();
    }

    match /customers/{customerId}/notifications/{notificationId} {
      allow read: if isAdmin() || isOwner(customerId);
      allow create: if isAdmin() || isOwner(customerId);
      allow update: if isAdmin() || isOwner(customerId);
      allow delete: if isAdmin();
    }

    match /customers/{customerId}/{document=**} {
      allow read, write: if isAdmin() || (isOwner(customerId) && !document.matches('^orders/.*'));
    }

    match /adminNotifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isValidCustomerToAdminNotificationCreate();
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
